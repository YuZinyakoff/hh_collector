# Runtime
# This file is shared by the Python app and Docker Compose.
# Compose-only keys below are ignored by Python Settings.
# Required on VPS: switch to `production`.
HHRU_ENV=local
HHRU_LOG_LEVEL=INFO
HHRU_LOG_FORMAT=json

# Database
# Required on VPS: set a strong non-default password before deploy.
HHRU_DB_HOST=localhost
HHRU_DB_PORT=5432
HHRU_DB_NAME=hhru_platform
HHRU_DB_USER=hhru
HHRU_DB_PASSWORD=change-me
HHRU_DB_BIND_HOST=127.0.0.1

# Redis
HHRU_REDIS_HOST=localhost
HHRU_REDIS_PORT=6379
HHRU_REDIS_DB=0
HHRU_REDIS_BIND_HOST=127.0.0.1

# Official hh API identity
# Required on VPS: replace the placeholder contact with a real mailbox or handle.
# The default value below is intentionally rejected for live `/vacancies` search.
# Optional for HH API auth benchmarking in the probe notebook.
# Keep empty if you want anonymous mode only.
HHRU_HH_API_BASE_URL=https://api.hh.ru
HHRU_HH_API_TIMEOUT_SECONDS=30
HHRU_HH_API_USER_AGENT=hhru-platform/0.1 (contact: change-me@example.com)
HHRU_HH_API_APPLICATION_TOKEN=

# Metrics and observability
HHRU_METRICS_HOST=0.0.0.0
HHRU_METRICS_PORT=8001
HHRU_METRICS_BIND_HOST=127.0.0.1
HHRU_METRICS_STATE_PATH=.state/metrics/metrics.json
# Compose-only UI/bind settings used by docker-compose port mappings and services.
HHRU_PROMETHEUS_PORT=9090
HHRU_PROMETHEUS_BIND_HOST=127.0.0.1
HHRU_PROMETHEUS_RETENTION_TIME=7d
HHRU_PROMETHEUS_RETENTION_SIZE=8GB
HHRU_GRAFANA_PORT=3000
HHRU_GRAFANA_BIND_HOST=127.0.0.1
HHRU_GRAFANA_ADMIN_USER=admin
# Required on VPS: replace the default password before exposing Grafana.
HHRU_GRAFANA_ADMIN_PASSWORD=admin
HHRU_ALERTMANAGER_PORT=9093
HHRU_ALERTMANAGER_BIND_HOST=127.0.0.1
HHRU_ALERT_WEBHOOK_HOST=0.0.0.0
HHRU_ALERT_WEBHOOK_PORT=8010
HHRU_ALERT_WEBHOOK_BIND_HOST=127.0.0.1
HHRU_NODE_EXPORTER_PORT=9100
HHRU_NODE_EXPORTER_BIND_HOST=127.0.0.1
HHRU_CADVISOR_PORT=8080
HHRU_CADVISOR_BIND_HOST=127.0.0.1
# Optional production alert delivery via Telegram.
# Leave empty locally to log Alertmanager payloads without external delivery.
HHRU_ALERT_TELEGRAM_BOT_TOKEN=
HHRU_ALERT_TELEGRAM_CHAT_ID=
HHRU_ALERT_TELEGRAM_DISABLE_NOTIFICATION=false

# Backups
HHRU_BACKUP_DIR=.state/backups
HHRU_BACKUP_RETENTION_DAYS=7
HHRU_BACKUP_PREFIX=hhru-platform
HHRU_BACKUP_RESTORE_DRILL_TARGET_DB=hhru_platform_restore_drill
HHRU_BACKUP_RESTORE_DRILL_DROP_EXISTING=true
HHRU_BACKUP_OFFSITE_BACKEND=webdav
HHRU_BACKUP_OFFSITE_URL=
HHRU_BACKUP_OFFSITE_ROOT=/hhru-platform/backups
HHRU_BACKUP_OFFSITE_USERNAME=
HHRU_BACKUP_OFFSITE_PASSWORD=
HHRU_BACKUP_OFFSITE_BEARER_TOKEN=
HHRU_BACKUP_OFFSITE_TIMEOUT_SECONDS=1800
HHRU_BACKUP_OFFSITE_CHUNK_SIZE_BYTES=4194304
HHRU_BACKUP_OFFSITE_S3_ENDPOINT_URL=
HHRU_BACKUP_OFFSITE_S3_BUCKET=
HHRU_BACKUP_OFFSITE_S3_REGION=ru-1
HHRU_BACKUP_OFFSITE_S3_ACCESS_KEY_ID=
HHRU_BACKUP_OFFSITE_S3_SECRET_ACCESS_KEY=

# Housekeeping / retention
HHRU_HOUSEKEEPING_RAW_API_PAYLOAD_RETENTION_DAYS=90
HHRU_HOUSEKEEPING_VACANCY_SNAPSHOT_RETENTION_DAYS=0
HHRU_HOUSEKEEPING_FINISHED_CRAWL_RUN_RETENTION_DAYS=90
HHRU_HOUSEKEEPING_DETAIL_FETCH_ATTEMPT_RETENTION_DAYS=180
HHRU_HOUSEKEEPING_REPORT_ARTIFACT_RETENTION_DAYS=30
HHRU_HOUSEKEEPING_REPORT_ARTIFACT_DIR=.state/reports/detail-payload-study
HHRU_HOUSEKEEPING_ARCHIVE_DIR=.state/archive/retention
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_URL=
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_ROOT=/hhru-platform
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_USERNAME=
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_PASSWORD=
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_BEARER_TOKEN=
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_TIMEOUT_SECONDS=60
HHRU_HOUSEKEEPING_DELETE_LIMIT_PER_TARGET=10000

# Research archive
HHRU_RESEARCH_ARCHIVE_DIR=.state/archive/research
HHRU_RESEARCH_ARCHIVE_OFFSITE_BACKEND=s3
HHRU_RESEARCH_ARCHIVE_OFFSITE_ROOT=/hhru-platform/research-archive
# Leave these empty to reuse HHRU_BACKUP_OFFSITE_S3_* settings.
HHRU_RESEARCH_ARCHIVE_OFFSITE_S3_ENDPOINT_URL=
HHRU_RESEARCH_ARCHIVE_OFFSITE_S3_BUCKET=
HHRU_RESEARCH_ARCHIVE_OFFSITE_S3_REGION=
HHRU_RESEARCH_ARCHIVE_OFFSITE_S3_ACCESS_KEY_ID=
HHRU_RESEARCH_ARCHIVE_OFFSITE_S3_SECRET_ACCESS_KEY=

# Detail worker / first-detail backlog
HHRU_DETAIL_WORKER_BATCH_SIZE=100
HHRU_DETAIL_WORKER_INTERVAL_SECONDS=300
HHRU_DETAIL_WORKER_INCLUDE_INACTIVE=no
HHRU_DETAIL_WORKER_TRIGGERED_BY=detail-worker
HHRU_DETAIL_WORKER_RETRY_COOLDOWN_SECONDS=3600
HHRU_DETAIL_WORKER_MAX_RETRY_COOLDOWN_SECONDS=86400
HHRU_DETAIL_WORKER_LEASE_SECONDS=7200

# Docker logging
HHRU_DOCKER_LOG_MAX_SIZE=20m
HHRU_DOCKER_LOG_MAX_FILE=5
