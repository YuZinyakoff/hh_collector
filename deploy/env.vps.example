# VPS production-like profile.
# Copy to `.env` on the VPS and replace every `change-me-*` value before use.

# Runtime
HHRU_ENV=production
HHRU_LOG_LEVEL=INFO
HHRU_LOG_FORMAT=json

# Database
HHRU_DB_HOST=localhost
HHRU_DB_PORT=5432
HHRU_DB_NAME=hhru_platform
HHRU_DB_USER=hhru
HHRU_DB_PASSWORD=change-me-strong-db-password
HHRU_DB_BIND_HOST=127.0.0.1

# Redis
HHRU_REDIS_HOST=localhost
HHRU_REDIS_PORT=6379
HHRU_REDIS_DB=0
HHRU_REDIS_BIND_HOST=127.0.0.1

# Official hh API identity
HHRU_HH_API_BASE_URL=https://api.hh.ru
HHRU_HH_API_TIMEOUT_SECONDS=30
HHRU_HH_API_USER_AGENT=hhru-platform/0.1 (contact: change-me@example.com)
HHRU_HH_API_APPLICATION_TOKEN=

# Metrics and observability
HHRU_METRICS_HOST=0.0.0.0
HHRU_METRICS_PORT=8001
HHRU_METRICS_BIND_HOST=127.0.0.1
HHRU_METRICS_STATE_PATH=.state/metrics/metrics.json
HHRU_PROMETHEUS_PORT=9090
HHRU_PROMETHEUS_BIND_HOST=127.0.0.1
HHRU_GRAFANA_PORT=3000
HHRU_GRAFANA_BIND_HOST=127.0.0.1
HHRU_GRAFANA_ADMIN_USER=admin
HHRU_GRAFANA_ADMIN_PASSWORD=change-me-strong-grafana-password

# Backups
HHRU_BACKUP_DIR=.state/backups
HHRU_BACKUP_RETENTION_DAYS=14
HHRU_BACKUP_PREFIX=hhru-platform
HHRU_BACKUP_RESTORE_DRILL_TARGET_DB=hhru_platform_restore_drill
HHRU_BACKUP_RESTORE_DRILL_DROP_EXISTING=true

# Housekeeping / retention
# For the VPS pilot, keep snapshots hot until the first successful full baseline is measured.
# After the pilot, switch cleanup to `--archive-before-delete` and verify offsite receipts first.
HHRU_HOUSEKEEPING_RAW_API_PAYLOAD_RETENTION_DAYS=90
HHRU_HOUSEKEEPING_VACANCY_SNAPSHOT_RETENTION_DAYS=0
HHRU_HOUSEKEEPING_FINISHED_CRAWL_RUN_RETENTION_DAYS=90
HHRU_HOUSEKEEPING_DETAIL_FETCH_ATTEMPT_RETENTION_DAYS=180
HHRU_HOUSEKEEPING_REPORT_ARTIFACT_RETENTION_DAYS=30
HHRU_HOUSEKEEPING_REPORT_ARTIFACT_DIR=.state/reports/detail-payload-study
HHRU_HOUSEKEEPING_ARCHIVE_DIR=.state/archive/retention
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_URL=https://webdav.yandex.ru
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_ROOT=/hhru-platform
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_USERNAME=change-me-yandex-login
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_PASSWORD=change-me-yandex-app-password
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_BEARER_TOKEN=
HHRU_HOUSEKEEPING_ARCHIVE_OFFSITE_TIMEOUT_SECONDS=60
HHRU_HOUSEKEEPING_DELETE_LIMIT_PER_TARGET=10000

# Detail worker / first-detail backlog
# Keep disabled for the first search-only VPS pilot; enable after the baseline is measured.
HHRU_DETAIL_WORKER_BATCH_SIZE=100
HHRU_DETAIL_WORKER_INTERVAL_SECONDS=300
HHRU_DETAIL_WORKER_INCLUDE_INACTIVE=no
HHRU_DETAIL_WORKER_TRIGGERED_BY=detail-worker
HHRU_DETAIL_WORKER_RETRY_COOLDOWN_SECONDS=3600
HHRU_DETAIL_WORKER_MAX_RETRY_COOLDOWN_SECONDS=86400
