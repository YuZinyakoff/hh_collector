          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Coverage Ratio"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "run_id": 0,
              "run_type": 1,
              "Value": 2
            },
            "renameByName": {
              "run_id": "Run ID",
              "run_type": "Run Type",
              "Value": "Coverage Ratio"
            }
          }
        }
      ]
